generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Order {
  orderId      String   @id
  value        Float
  creationDate DateTime
  items        Items[]
}

model Items {
  id        Int    @id @default(autoincrement())
  orderId   String
  productId Int
  quantity  Int
  price     Float
  order     Order  @relation(fields: [orderId], references: [orderId])
}
